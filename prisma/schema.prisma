generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("L1_AGENT") // "L1_AGENT", "L2_APPROVAL", "L3_PO_MAKER", "L4_ADMIN"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model FarmerSequence {
  monthKey String @id // format: "YYMM" e.g., "2604"
  lastSeq  Int    @default(0)
}

model Farmer {
  id               Int      @id @default(autoincrement())
  name             String
  phone            String   @default("")
  address          String   @default("")
  town             String   @default("")
  village          String   @default("")
  district         String   @default("")
  block            String   @default("")
  fatherName       String   @default("")
  gender           String   @default("")
  pinCode          String   @default("")
  projectName      String   @default("")
  category         String   @default("FARMER") // "FARMER" or "TRADER"
  farmerCode       String   @unique
  registeredBy     String   @default("")  // Agent user ID who registered this farmer
  registeredByName String   @default("")  // Agent name for display
  assignedL3Id     String   @default("")  // PO Maker (Level 3) who is assigned to this farmer
  createdByAdmin   Boolean  @default(false)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  procurements Procurement[]

  @@map("farmers")
}

model Procurement {
  id            Int      @id @default(autoincrement())
  slipId        String   @unique
  farmerId      Int
  farmer        Farmer   @relation(fields: [farmerId], references: [id])
  farmerName    String   @default("")
  fatherName    String   @default("")
  farmerCode    String   @default("")
  village       String   @default("")
  crop          String
  variety       String   @default("")
  bags          Int      @default(0)
  packingSize   Int      @default(0)
  grossQuantity Float    @default(0)
  deduction     Float    @default(0)
  netQuantity   Float    @default(0)
  rate          Float    @default(0)
  bones         Float    @default(0)
  total         Float    @default(0)
  adtiyaName    String   @default("")
  lotNo         String   @default("")
  agentId       String   @default("")  // Agent user ID who did this procurement
  agentName     String   @default("")
  status        String   @default("PENDING_L2") // PENDING_L2, REJECTED_L2, PENDING_L3, REJECTED_L3, APPROVED
  l2ApprovedBy  String   @default("")
  l3ApprovedBy  String   @default("")
  createdByAdmin Boolean @default(false)
  validated     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("procurements")
}
